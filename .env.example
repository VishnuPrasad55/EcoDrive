# ============================================================
# EcoDrive - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Mapbox Configuration (for interactive maps)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Google Maps (alternative to Mapbox)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# AI / Python Microservice (optional)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your-ai-service-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EcoDrive

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
